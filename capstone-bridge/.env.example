# Bridge service
BRIDGE_PORT=3001
BRIDGE_API_KEY=your-secure-api-key-here

# Ethereum
ETHEREUM_RPC_URL=http://127.0.0.1:8545
DEPLOYER_PRIVATE_KEY=

# Deployed contract addresses (from capstone-blockchain deploy script)
PROCUREMENT_REGISTRY_ADDRESS=
BID_MANAGER_ADDRESS=
PAYMENT_TRACKER_ADDRESS=

# Laravel webhook (for on-chain event confirmations)
LARAVEL_WEBHOOK_URL=http://127.0.0.1:8000/api/internal/blockchain-webhook
LARAVEL_WEBHOOK_KEY=your-webhook-key-here
